    def on_dimensions_change(self):
        """При изменении размера - пересоздаём все поля"""
        new_sources = self.sources_var.get()
        new_destinations = self.destinations_var.get()

        if new_sources != self.num_sources or new_destinations != self.num_destinations:
            self.num_sources = new_sources
            self.num_destinations = new_destinations
            self.create_input_tab()

    def get_table_data(self):
        """Получить данные из таблиц"""
        try:
            num_sources = self.sources_var.get()
            num_destinations = self.destinations_var.get()

            # Ошибка пустого предложения
            supply = []
            for i in range(num_sources):
                if i < len(self.supply_entries):
                    val = self.supply_entries[i].get().strip()
                    if not val:
                        messagebox.showerror('Ошибка', f'Поле предложения S{i+1} пусто!')
                        return None, None, None
                    supply.append(int(val))

            # Ошибка пустого спроса
            demand = []
            for j in range(num_destinations):
                if j < len(self.demand_entries):
                    val = self.demand_entries[j].get().strip()
                    if not val:
                        messagebox.showerror('Ошибка', f'Поле спроса D{j+1} пусто!')
                        return None, None, None
                    demand.append(int(val))

            # Ошибка пустой матрицы затрат
            cost_matrix = []
            for i in range(num_sources):
                row = []
                for j in range(num_destinations):
                    if i < len(self.cost_entries) and j < len(self.cost_entries[i]):
                        val = self.cost_entries[i][j].get().strip()
                        if not val:
                            messagebox.showerror('Ошибка', f'Поле Cost[{i+1}][{j+1}] пусто!')
                            return None, None, None
                        row.append(int(val))
                if row:
                    cost_matrix.append(row)

            print(f"Предложение: {supply}")
            print(f"Спрос: {demand}")
            print(f"Матрица затрат: {cost_matrix}")

            return supply, demand, cost_matrix
        except (ValueError, IndexError) as e:
            messagebox.showerror('Ошибка', f'Пожалуйста, введите только числовые значения!\nОшибка: {str(e)}')
            return None, None, None

    def northwest_corner_method(self, supply, demand, cost_matrix):
        """Решить задачу методом северо-западного угла"""
        print("Начало расчета...")

        supply_copy = supply.copy()
        demand_copy = demand.copy()

        allocation = [[0] * len(demand) for _ in range(len(supply))]

        # Проверка баланса
        if sum(supply) != sum(demand):
            print(f"Несбалансирована! Преложение: {sum(supply)}, Спрос: {sum(demand)}")
            return allocation, 0, False

        i = 0
        j = 0

        print(f"Начальные данные - Источники: {len(supply)}, Цели: {len(demand)}")

        while i < len(supply) and j < len(demand):
            allocation_amount = min(supply_copy[i], demand_copy[j])
            allocation[i][j] = allocation_amount

            print(f"Распределение: S{i+1} -> D{j+1}: {allocation_amount}")

            supply_copy[i] -= allocation_amount
            demand_copy[j] -= allocation_amount

            if supply_copy[i] == 0:
                i += 1
            if demand_copy[j] == 0:
                j += 1

        # Вычислить общую стоимость
        total_cost = 0
        for i in range(len(supply)):
            for j in range(len(demand)):
                if allocation[i][j] > 0:
                    total_cost += allocation[i][j] * cost_matrix[i][j]
                    print(f"Стоимость: {allocation[i][j]} * {cost_matrix[i][j]} = {allocation[i][j] * cost_matrix[i][j]}")

        print(f"Итоговая стоимость: {total_cost}")

        return allocation, total_cost, True

    def modi_optimization(self, allocation, cost_matrix, supply, demand):
        """Оптимизировать решение методом МОДИ (модифицированный распределительный метод)"""
        print("\n=== НАЧАЛО ОПТИМИЗАЦИИ (МОДИ) ===")
        
        # Создаём копию распределения для работы
        allocation = [row[:] for row in allocation]
        num_sources = len(supply)
        num_destinations = len(demand)
        
        iteration = 0
        max_iterations = 100
        
        while iteration < max_iterations:
            iteration += 1
            print(f"\n--- Итерация {iteration} ---")
            
            # Определить базисные ячейки (где allocation > 0)
            basic_cells = []
            for i in range(num_sources):
                for j in range(num_destinations):
                    if allocation[i][j] > 0:
                        basic_cells.append((i, j))
            
            print(f"Базисных ячеек: {len(basic_cells)}")
            
            # Вычислить u и v (двойственные переменные)
            u = [None] * num_sources
            v = [None] * num_destinations
            u[0] = 0  # Начинаем с u[0] = 0
            
            # Итеративно находим u и v используя условие: u[i] + v[j] = cost[i][j] для базисных ячеек
            changed = True
            safety_counter = 0
            while changed and safety_counter < 100:
                changed = False
                safety_counter += 1
                for i, j in basic_cells:
                    if u[i] is not None and v[j] is None:
                        v[j] = cost_matrix[i][j] - u[i]
                        changed = True
                    elif v[j] is not None and u[i] is None:
                        u[i] = cost_matrix[i][j] - v[j]
                        changed = True
            
            # Если не все u и v определены, используем альтернативный подход
            for i in range(num_sources):
                if u[i] is None:
                    u[i] = 0
            for j in range(num_destinations):
                if v[j] is None:
                    v[j] = 0
            
            print(f"u значения: {u}")
            print(f"v значения: {v}")
            
            # Вычислить стоимости возможностей (opportunity costs) для небазисных ячеек
            opportunity_costs = {}
            entering_cell = None
            min_opportunity_cost = 0
            
            for i in range(num_sources):
                for j in range(num_destinations):
                    if allocation[i][j] == 0:  # небазисная ячейка
                        opportunity_cost = cost_matrix[i][j] - u[i] - v[j]
                        opportunity_costs[(i, j)] = opportunity_cost
                        
                        if opportunity_cost < min_opportunity_cost:
                            min_opportunity_cost = opportunity_cost
                            entering_cell = (i, j)
            
            # Проверить оптимальность
            if min_opportunity_cost >= 0:
                print("Оптимальное решение найдено!")
                break
            
            print(f"Входящая ячейка: {entering_cell}, стоимость возможности: {min_opportunity_cost}")
            
            # Построить цикл (loop) для перераспределения
            loop = self.find_loop(entering_cell, basic_cells, num_sources, num_destinations)
            
            if not loop:
                print("Не удалось найти цикл, завершаем оптимизацию")
                break
            
            print(f"Найден цикл: {loop}")
            
            # Найти максимальное количество для перераспределения
            min_allocation = float('inf')
            for idx, (i, j) in enumerate(loop):
                if idx % 2 == 1:  # нечетные позиции (минусы)
                    if allocation[i][j] < min_allocation:
                        min_allocation = allocation[i][j]
            
            print(f"Перераспределяемое количество: {min_allocation}")
            
            # Перераспределить
            for idx, (i, j) in enumerate(loop):
                if idx % 2 == 0:  # четные позиции (плюсы)
                    allocation[i][j] += min_allocation
                else:  # нечетные позиции (минусы)
                    allocation[i][j] -= min_allocation
        
        # Вычислить оптимальную стоимость
        optimized_cost = 0
        for i in range(num_sources):
            for j in range(num_destinations):
                if allocation[i][j] > 0:
                    optimized_cost += allocation[i][j] * cost_matrix[i][j]
        
        print(f"\nОптимизированная стоимость: {optimized_cost}")
        print("=== ОПТИМИЗАЦИЯ ЗАВЕРШЕНА ===\n")
        
        return allocation, optimized_cost
    
    def find_loop(self, entering_cell, basic_cells, num_sources, num_destinations):
        """Найти цикл для перераспределения (упрощенная версия)"""
        # Добавить входящую ячейку в список для поиска цикла
        cells = basic_cells + [entering_cell]
        
        # Простой поиск цикла: найти путь который возвращается к начальной ячейке
        # используя только горизонтальные и вертикальные движения
        start = entering_cell
        
        # Создаём словари для быстрого поиска
        rows_dict = {}
        cols_dict = {}
        
        for cell in cells:
            i, j = cell
            if i not in rows_dict:
                rows_dict[i] = []
            rows_dict[i].append(j)
            
            if j not in cols_dict:
                cols_dict[j] = []
            cols_dict[j].append(i)
        
        # Простой алгоритм поиска прямоугольного цикла
        start_i, start_j = start
        
        # Пробуем найти простой прямоугольный цикл
        if start_i in rows_dict:
            for j2 in rows_dict[start_i]:
                if j2 != start_j and j2 in cols_dict:
                    for i2 in cols_dict[j2]:
                        if i2 != start_i and i2 in rows_dict:
                            if start_j in rows_dict[i2]:
                                # Найден прямоугольный цикл
                                loop = [
                                    (start_i, start_j),
                                    (start_i, j2),
                                    (i2, j2),
                                    (i2, start_j)
                                ]
                                return loop
        
        # Если простой цикл не найден, возвращаем минимальный цикл
        # (для упрощения используем первые доступные ячейки)
        if len(cells) >= 4:
            return cells[:4]
        
        return None

    def solve_problem(self):
        """Решить задачу"""
        print("\n=== НАЧАЛО РЕШЕНИЯ ===")

        supply, demand, cost_matrix = self.get_table_data()

        if supply is None:
            print("Ошибка при получении данных!")
            return

        num_sources = len(supply)
        num_destinations = len(demand)

        allocation, total_cost, feasible = self.northwest_corner_method(
            supply, demand, cost_matrix
        )

        if not feasible:
            messagebox.showerror(
                'Ошибка',
                f'Задача несбалансирована!\n\nПредложение (Supply): {sum(supply)}\nСпрос (Demand): {sum(demand)}\n\nОни должны быть равны!'
            )
            self.status_label.config(text='❌ Несбалансирована', fg='#f44336')
            return

        # Очистить текстовые поля для начального решения
        self.allocation_text.config(state=tk.NORMAL)
        self.allocation_text.delete(1.0, tk.END)

        # Отобразить начальную матрицу распределения
        # Заголовок
        self.allocation_text.insert(tk.END, 'НАЧАЛЬНОЕ РЕШЕНИЕ (Северо-западный угол)\n\n')
        header = '       ' + ''.join(f'D{j+1:<7}' for j in range(num_destinations))
        self.allocation_text.insert(tk.END, header + '\n')
        self.allocation_text.insert(tk.END, '-' * (len(header) + 10) + '\n')

        for i in range(num_sources):
            line = f'S{i+1:<4}  '
            for j in range(num_destinations):
                line += f'{allocation[i][j]:<7}'
            self.allocation_text.insert(tk.END, line + '\n')

        self.allocation_text.insert(tk.END, f'\nСтоимость начального решения: {total_cost}\n')
        self.allocation_text.config(state=tk.DISABLED)

        # Выполнить оптимизацию
        optimized_allocation, optimized_cost = self.modi_optimization(
            allocation, cost_matrix, supply, demand
        )

        # Очистить и отобразить оптимизированную матрицу
        self.optimized_text.config(state=tk.NORMAL)
        self.optimized_text.delete(1.0, tk.END)

        self.optimized_text.insert(tk.END, 'ОПТИМИЗИРОВАННОЕ РЕШЕНИЕ (Метод МОДИ)\n\n')
        header = '       ' + ''.join(f'D{j+1:<7}' for j in range(num_destinations))
        self.optimized_text.insert(tk.END, header + '\n')
        self.optimized_text.insert(tk.END, '-' * (len(header) + 10) + '\n')

        for i in range(num_sources):
            line = f'S{i+1:<4}  '
            for j in range(num_destinations):
                line += f'{optimized_allocation[i][j]:<7}'
            self.optimized_text.insert(tk.END, line + '\n')

        self.optimized_text.insert(tk.END, f'\nСтоимость оптимизированного решения: {optimized_cost}\n')
        improvement = total_cost - optimized_cost
        if improvement > 0:
            self.optimized_text.insert(tk.END, f'Улучшение: {improvement} ({improvement/total_cost*100:.1f}%)\n')
        else:
            self.optimized_text.insert(tk.END, 'Начальное решение уже было оптимальным\n')
        self.optimized_text.config(state=tk.DISABLED)

        # Отобразить детали
        self.details_text.config(state=tk.NORMAL)
        self.details_text.delete(1.0, tk.END)

        header = f'{"Источник":<12} {"Пункт":<12} {"Кол-во":<10} {"Стоим/ед":<12} {"Сумма":<10}\n'
        self.details_text.insert(tk.END, header)
        self.details_text.insert(tk.END, '-' * 56 + '\n')

        for i in range(num_sources):
            for j in range(num_destinations):
                if optimized_allocation[i][j] > 0:
                    unit_cost = cost_matrix[i][j]
                    alloc_cost = optimized_allocation[i][j] * unit_cost
                    line = f'S{i+1:<11} D{j+1:<11} {optimized_allocation[i][j]:<10} {unit_cost:<12} {alloc_cost:<10}\n'
                    self.details_text.insert(tk.END, line)

        self.details_text.config(state=tk.DISABLED)

        # Обновить информацию (показываем оптимизированную стоимость)
        self.cost_label.config(text=str(optimized_cost))
        self.status_label.config(text='✅ Решено успешно', fg='#4CAF50')

        # Переключиться на вкладку решения
        self.notebook.select(1)

        messagebox.showinfo('✅ Успех', f'Задача решена и оптимизирована!\n\nНачальная стоимость: {total_cost}\nОптимизированная стоимость: {optimized_cost}\nУлучшение: {total_cost - optimized_cost}')
        print("=== РЕШЕНИЕ ЗАВЕРШЕНО ===\n")


def main():
    """Главная функция"""
    root = tk.Tk()
    app = TransportationSolverGUI(root)
    root.mainloop()


if __name__ == '__main__':
    main()
